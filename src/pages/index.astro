---
import Layout from '../layouts/Layout.astro';
import EntryCard from '../components/EntryCard.astro';
import profile from '../config/profile.json';
import OtherContent from '../content/posts/other.md';
import { collectionList, getCollectionItems } from '../lib/collections';

// 每个集合面板的数据 + 配置
const panels = collectionList.map((config) => ({
  config,
  items: getCollectionItems(config),
}));

// 标签页：集合 + “其他”
const viewerTabs = [
  ...collectionList.map((config) => ({ key: config.key, label: config.navLabel })),
  { key: 'other', label: '其他' },
];

const otherCopy = {
  eyebrow: 'Other',
  title: '看起来，你想要更加了解我……',
  desc: 'More about me.',
};

type ProfileActionLink = {
  href: string;
  label: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
};

const configuredProfileLinks = (profile as { links?: Partial<ProfileActionLink>[] }).links ?? [];
const profileLinks = configuredProfileLinks
  .filter((link): link is ProfileActionLink => Boolean(link.href?.trim() && link.label?.trim()))
  .map((link) => {
    const href = link.href.trim();
    const target = link.target ?? (/^https?:\/\//i.test(href) ? '_blank' : undefined);

    return {
      ...link,
      href,
      label: link.label.trim(),
      target,
      rel: link.rel ?? (target === '_blank' ? 'noreferrer' : undefined),
    };
  });

const socialLinks = Object.entries(profile.social)
  .filter(([, url]) => Boolean(url))
  .map(([platform, url]) => ({
    platform,
    url: platform === 'email' && typeof url === 'string' && !url.startsWith('mailto:') ? `mailto:${url}` : url,
  }));

const iconPaths: Record<string, string> = {
  github: 'M12 2C6.5 2 2 6.5 2 12.2c0 4.6 3 8.4 7.1 9.8.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.6-1.1-1.6-.9-.7.1-.7.1-.7 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5.5 0-1.2.4-2.1 1.1-2.9-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1.8-.2 1.7-.4 2.6-.4s1.8.1 2.6.4c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.8 1.1 1.7 1.1 2.9 0 4.3-2.4 5.2-4.7 5.5.4.4.8 1 .8 2v2.9c0 .3.2.6.7.5 4.1-1.4 7.1-5.2 7.1-9.8C22 6.5 17.5 2 12 2Z',
  email: 'M4 6.5h16c.8 0 1.5.7 1.5 1.5v8c0 .8-.7 1.5-1.5 1.5H4c-.8 0-1.5-.7-1.5-1.5V8c0-.8.7-1.5 1.5-1.5Zm0 1.6v.2l8 5.1 8-5.1v-.2H4Zm16 8.8V10l-7.6 4.8c-.2.1-.5.1-.8 0L4 10v6.9h16Z',
  default: 'M5 12h14M12 5l7 7-7 7',
};

function getSocialIcon(platform: string): string {
  return iconPaths[platform.toLowerCase()] || iconPaths.default;
}
---

<Layout title="Homepage" wallpaper={profile.wallpaper} heroFullscreen={true}>
  <div slot="hero" class="landing-hero">
    <div class="landing-hero-content">
      <div class="profile-center-container">
        <div class="profile-badge-wrapper">
          <div class="profile-panel__badge">Homepage</div>
        </div>
        <section class="profile-panel profile-panel--landing">
          <div class="profile-panel__header">
            <img src={profile.avatar} alt={profile.name} class="profile-avatar" />
            <div>
              <p class="page-kicker page-kicker--hero">Personal logbook</p>
              <h1 class="landing-title">{profile.name}</h1>
            </div>
          </div>
          <p class="landing-bio">{profile.bio}</p>

          <div class="social-icon-row" aria-label="社交媒体">
            {socialLinks.map(({ platform, url }) => (
              <a href={url as string} target="_blank" class="social-icon-button" aria-label={platform} title={platform}>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d={getSocialIcon(platform)} />
                </svg>
              </a>
            ))}
            {profileLinks.map((link) => (
              <a href={link.href} target={link.target} rel={link.rel} class="external-link-button">
                {link.label}
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>

  <section class="stack home-stage" id="collections">
    <div class="content-stage">
      <div class="content-tabs" id="content-tabs" role="tablist" aria-label="内容切换">
        {viewerTabs.map((tab, index) => (
          <button type="button" class="content-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-view={tab.key}>
            {tab.label}
          </button>
        ))}
      </div>

      <div class="content-viewer" data-content-viewer>
        <div class="content-viewer__panels">
          {panels.map(({ config, items }, index) => (
            <section class="content-panel" data-panel={config.key} data-active={index === 0 ? 'true' : undefined}>
              <div class="content-panel__summary">
                <p class="section-eyebrow" id={`section-eyebrow-${config.key}`}>{config.titleEn}</p>
                <h3>{config.subtitle}</h3>
                <p>{config.panelDesc}</p>
              </div>
              {items.length > 0 ? (
                <div class="content-panel__list">
                  {items.map((item) => (
                    <EntryCard
                      item={item}
                      tag={config.tag}
                      variant={config.variant}
                      coverKeys={config.coverKeys}
                      metaFields={config.metaFields}
                      descFallback={config.descFallback}
                    />
                  ))}
                </div>
              ) : (
                <div class="empty-state">{config.emptyText}</div>
              )}
            </section>
          ))}

          <section class="content-panel" data-panel="other">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-other">{otherCopy.eyebrow}</p>
              <h3>{otherCopy.title}</h3>
              <p>{otherCopy.desc}</p>
            </div>
            <div class="prose-card">
              <OtherContent />
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const viewer = document.querySelector<HTMLElement>('[data-content-viewer]');
    const tabs = Array.from(document.querySelectorAll<HTMLElement>('[data-view]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));

    // 向下箭头：平滑滚动到内容标签栏
    const scrollLink = document.querySelector('.hero-scroll-link');
    if (scrollLink) {
      scrollLink.addEventListener('click', (event) => {
        event.preventDefault();
        const contentTabs = document.getElementById('content-tabs');
        if (!contentTabs) return;

        const rect = contentTabs.getBoundingClientRect();
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        window.scrollTo({ top: rect.top + scrollTop, behavior: 'smooth' });
      });
    }

    if (!viewer || !tabs.length || !panels.length) return;

    const keys = tabs.map((tab) => tab.dataset.view);
    const panelMap = Object.fromEntries(panels.map((panel) => [panel.dataset.panel, panel]));

    const getCurrentKey = () => viewer.dataset.activeView || 'games';
    const setCurrentKey = (key: string) => { viewer.dataset.activeView = key; };

    const setActive = (key: string | undefined, forceScroll = false) => {
      if (!key || !panelMap[key]) return;

      const isSameTab = getCurrentKey() === key;
      const targetPanel = panelMap[key];
      const firstChild = targetPanel.firstElementChild;
      const contentTabs = document.getElementById('content-tabs');

      tabs.forEach((tab) => tab.setAttribute('aria-selected', 'false'));
      panels.forEach((panel) => panel.removeAttribute('data-active'));
      targetPanel.setAttribute('data-active', 'true');
      tabs.find((tab) => tab.dataset.view === key)?.setAttribute('aria-selected', 'true');
      setCurrentKey(key);

      if (!contentTabs || !firstChild) return;

      const tabsRect = contentTabs.getBoundingClientRect();
      const firstChildRect = firstChild.getBoundingClientRect();
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      const isTabsSticky = tabsRect.top >= -10 && tabsRect.top <= 20;

      let shouldScroll = false;
      let targetScrollTop = scrollTop;

      if (isTabsSticky) {
        const tabsHeight = tabsRect.height;
        const isContentObscured = firstChildRect.top < tabsHeight + 20;
        if (isContentObscured || forceScroll) {
          shouldScroll = true;
          targetScrollTop = scrollTop + firstChildRect.top - tabsHeight - 20;
        }
      } else if (!isSameTab || forceScroll) {
        shouldScroll = true;
        targetScrollTop = tabsRect.top + scrollTop;
      }

      if (shouldScroll && Math.abs(targetScrollTop - scrollTop) > 5) {
        window.scrollTo({ top: Math.max(0, targetScrollTop), behavior: 'smooth' });
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const clickedKey = tab.dataset.view || 'games';
        setActive(clickedKey, clickedKey === getCurrentKey());
      });
    });
  });

  // 移动端视口高度修正：解决浏览器地址栏动态变化
  const setVH = () => {
    const height = window.visualViewport ? window.visualViewport.height : window.innerHeight;
    document.documentElement.style.setProperty('--vh', `${height}px`);
  };

  let resizeTimer: ReturnType<typeof setTimeout>;
  const handleResize = () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(setVH, 50);
  };

  if (window.visualViewport) {
    window.visualViewport.addEventListener('resize', setVH);
  }
  window.addEventListener('resize', handleResize);
  window.addEventListener('orientationchange', () => setTimeout(handleResize, 100));
  window.addEventListener('load', () => setTimeout(handleResize, 100));
  setVH();
</script>
