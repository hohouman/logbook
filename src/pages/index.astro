---
// 导入页面布局组件
import Layout from '../layouts/Layout.astro';

// 加载个人资料配置数据
import profile from '../config/profile.json';
import gamesData from '../content/_generated/games.json';
import moviesData from '../content/_generated/movies.json';
import booksData from '../content/_generated/books.json';
import albumsData from '../content/_generated/albums.json';
import OtherContent from '../content/posts/other.md';

const games = Array.isArray(gamesData) ? gamesData : (gamesData.items || []);
const movies = Array.isArray(moviesData) ? moviesData : (moviesData.items || []);
const books = Array.isArray(booksData) ? booksData : (booksData.items || []);
const albums = Array.isArray(albumsData) ? albumsData : (albumsData.items || []);

const fallbackAlbumNotes = [
  {
    title: '正在循环',
    desc: '这里以后可以放最近听得最多的专辑、歌单或者一些值得反复回听的作品。',
  },
  {
    title: '喜欢的声音',
    desc: '偏爱的风格、制作人的名字、某种总会被我反复记住的气质。',
  },
  {
    title: '听歌记录',
    desc: '我会把专辑页当作比歌单更安静的一种笔记空间。',
  },
];

const albumCards = albums.length > 0 ? albums : fallbackAlbumNotes.map((item, index) => ({
  id: `album-note-${index}`,
  title: item.title,
  artist: 'Personal note',
  description: item.desc,
  type: 'album',
}));

const externalLinks = [
  { href: 'https://blog.houman.top', label: '我的博客' },
  { href: 'https://9sing.houman.top', label: '我的大音劲' },
];

const socialLinks = Object.entries(profile.social)
  .filter(([, url]) => Boolean(url))
  .map(([platform, url]) => ({
    platform,
    url: platform === 'email' && typeof url === 'string' && !url.startsWith('mailto:') ? `mailto:${url}` : url,
  }));

const viewerTabs = [
  { key: 'games', label: '游戏' },
  { key: 'movies', label: '电影' },
  { key: 'books', label: '小说' },
  { key: 'albums', label: '专辑' },
  { key: 'other', label: '其他' },
];

const panelCopy = {
  games: {
    eyebrow: 'Games',
    title: '那些我玩过的游戏',
    desc: '封面和发行信息放在一起，像一排可以随手翻看的游戏盒。',
    tag: 'Game',
  },
  movies: {
    eyebrow: 'Movies',
    title: '那些我看过的影片',
    desc: '每一张海报，都是电影的第一句台词。',
    tag: 'Movie',
  },
  books: {
    eyebrow: 'Books',
    title: '那些我读过的小说',
    desc: '像书架一样陈列封面、作者和出版时间，安静但容易回看。',
    tag: 'Book',
  },
  albums: {
    eyebrow: 'Albums',
    title: '那些我爱听的CD',
    desc: '唱片封面、歌手和发行信息并排呈现，保留一点翻专辑的感觉。',
    tag: 'Album',
  },
  other: {
    eyebrow: 'Other',
    title: '看起来，你想要更加了解我……',
    desc: 'More about me.',
  },
};

const iconPaths = {
  github: 'M12 2C6.5 2 2 6.5 2 12.2c0 4.6 3 8.4 7.1 9.8.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.6-1.1-1.6-.9-.7.1-.7.1-.7 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5.5 0-1.2.4-2.1 1.1-2.9-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1.8-.2 1.7-.4 2.6-.4s1.8.1 2.6.4c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.8 1.1 1.7 1.1 2.9 0 4.3-2.4 5.2-4.7 5.5.4.4.8 1 .8 2v2.9c0 .3.2.6.7.5 4.1-1.4 7.1-5.2 7.1-9.8C22 6.5 17.5 2 12 2Z',
  email: 'M4 6.5h16c.8 0 1.5.7 1.5 1.5v8c0 .8-.7 1.5-1.5 1.5H4c-.8 0-1.5-.7-1.5-1.5V8c0-.8.7-1.5 1.5-1.5Zm0 1.6v.2l8 5.1 8-5.1v-.2H4Zm16 8.8V10l-7.6 4.8c-.2.1-.5.1-.8 0L4 10v6.9h16Z',
  default: 'M5 12h14M12 5l7 7-7 7',
};

function getSocialIcon(platform) {
  const key = platform.toLowerCase();
  return iconPaths[key] || iconPaths.default;
}
---

<Layout title="Homepage" wallpaper={profile.wallpaper} heroFullscreen={true}>
  <div slot="hero" class="landing-hero">
    <div class="landing-hero-content">
      <div class="profile-badge-wrapper">
        <div class="profile-panel__badge">Homepage</div>
      </div>
      <section class="profile-panel profile-panel--landing">
        <div class="profile-panel__header">
          <img src={profile.avatar} alt={profile.name} class="profile-avatar" />
          <div>
            <p class="page-kicker page-kicker--hero">Personal logbook</p>
            <h1 class="landing-title">{profile.name}</h1>
          </div>
        </div>
        <p class="landing-bio">{profile.bio}</p>

        <div class="social-icon-row" aria-label="社交媒体">
          {socialLinks.map(({ platform, url }) => (
            <a href={url as string} target="_blank" class="social-icon-button" aria-label={platform} title={platform} key={platform}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={getSocialIcon(platform)} />
              </svg>
            </a>
          ))}
          {externalLinks.map((link) => (
            <a href={link.href} target="_blank" class="external-link-button">
              {link.label}
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>

  <section class="stack home-stage" id="collections">
    <div class="content-stage">
      <div class="content-tabs" id="content-tabs" role="tablist" aria-label="内容切换">
        {viewerTabs.map((tab, index) => (
          <button type="button" class="content-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-view={tab.key}>
            {tab.label}
          </button>
        ))}
      </div>

      <div class="content-viewer" data-content-viewer>
        <div class="content-viewer__panels">
          <section class="content-panel" data-panel="games" data-active="true">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-games">{panelCopy.games.eyebrow}</p>
              <h3>{panelCopy.games.title}</h3>
              <p>{panelCopy.games.desc}</p>
            </div>
            {games.length > 0 ? (
              <div class="content-panel__list">
                {games.map((game) => (
                  <a href={game.url} target="_blank" style="text-decoration: none; color: inherit;">
                    <article class={`showcase-card${game.localPosterPath ? '' : ' showcase-card--wide-media'}`}>
                      <div class="entry-card__media">
                        {game.localPosterPath || game.localCoverPath ? <img src={game.localPosterPath || game.localCoverPath} alt={game.title} loading="lazy" /> : null}
                      </div>
                      <div class="entry-card__body">
                        <span class="card-tag">{panelCopy.games.tag}</span>
                        <h3 class="entry-card__title">{game.title}</h3>
                        {game.description ? <p class="entry-card__desc">{game.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                        <div class="entry-card__meta">
                          <div><strong>Developer:</strong> {Array.isArray(game.developer) ? game.developer.join(', ') : game.developer || 'Unknown'}</div>
                          <div><strong>Publisher:</strong> {Array.isArray(game.publisher) ? game.publisher.join(', ') : game.publisher || 'Unknown'}</div>
                          <div><strong>Release:</strong> {game.releaseDate || 'TBA'}</div>
                        </div>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            ) : (
              <div class="empty-state">No games added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="movies">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-movies">{panelCopy.movies.eyebrow}</p>
              <h3>{panelCopy.movies.title}</h3>
              <p>{panelCopy.movies.desc}</p>
            </div>
            {movies.length > 0 ? (
              <div class="content-panel__list">
                {movies.map((movie) => (
                  <a href={movie.url} target="_blank" style="text-decoration: none; color: inherit;">
                    <article class="showcase-card">
                      <div class="entry-card__media">
                        {movie.localCoverPath ? <img src={movie.localCoverPath} alt={movie.title} loading="lazy" /> : null}
                      </div>
                      <div class="entry-card__body">
                        <span class="card-tag">{panelCopy.movies.tag}</span>
                        <h3 class="entry-card__title">{movie.title}</h3>
                        {movie.description ? <p class="entry-card__desc">{movie.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                        <div class="entry-card__meta">
                          <div><strong>Director:</strong> {Array.isArray(movie.director) ? movie.director.join(', ') : movie.director || 'Unknown'}</div>
                          <div><strong>Release:</strong> {movie.releaseDate || 'TBA'}</div>
                        </div>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            ) : (
              <div class="empty-state">No movies added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="books">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-books">{panelCopy.books.eyebrow}</p>
              <h3>{panelCopy.books.title}</h3>
              <p>{panelCopy.books.desc}</p>
            </div>
            {books.length > 0 ? (
              <div class="content-panel__list">
                {books.map((book) => (
                  <a href={book.url} target="_blank" style="text-decoration: none; color: inherit;">
                    <article class="showcase-card">
                      <div class="entry-card__media">
                        {book.localCoverPath ? <img src={book.localCoverPath} alt={book.title} loading="lazy" /> : null}
                      </div>
                      <div class="entry-card__body">
                        <span class="card-tag">{panelCopy.books.tag}</span>
                        <h3 class="entry-card__title">{book.title}</h3>
                        {book.description ? <p class="entry-card__desc">{book.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                        <div class="entry-card__meta">
                          <div><strong>Author:</strong> {Array.isArray(book.author) ? book.author.join(', ') : book.author || (Array.isArray(book.developer) ? book.developer.join(', ') : book.developer) || 'Unknown'}</div>
                          <div><strong>Publisher:</strong> {Array.isArray(book.publisher) ? book.publisher.join(', ') : book.publisher || 'Unknown'}</div>
                          <div><strong>Release:</strong> {book.releaseDate || 'TBA'}</div>
                        </div>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            ) : (
              <div class="empty-state">No books added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="albums">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-albums">{panelCopy.albums.eyebrow}</p>
              <h3>{panelCopy.albums.title}</h3>
              <p>{panelCopy.albums.desc}</p>
            </div>
            {albumCards.length > 0 ? (
              <div class="content-panel__list">
                {albumCards.map((item) => (
                  item.url ? (
                    <a href={item.url} target="_blank" style="text-decoration: none; color: inherit;">
                      <article class={`showcase-card${item.localCoverPath ? '' : ' showcase-card--wide-media'}`}>
                        <div class="entry-card__media">
                          {item.localCoverPath ? <img src={item.localCoverPath} alt={item.title} loading="lazy" /> : null}
                        </div>
                        <div class="entry-card__body">
                          <span class="card-tag">{panelCopy.albums.tag}</span>
                          <h3 class="entry-card__title">{item.title}</h3>
                          {item.description ? <p class="entry-card__desc">{item.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                          <div class="entry-card__meta">
                            {item.artist && <div><strong>Artist:</strong> {Array.isArray(item.artist) ? item.artist.join(', ') : item.artist}</div>}
                            {item.publisher && <div><strong>Publisher:</strong> {Array.isArray(item.publisher) ? item.publisher.join(', ') : item.publisher}</div>}
                            {item.releaseDate && <div><strong>Release:</strong> {item.releaseDate}</div>}
                          </div>
                        </div>
                      </article>
                    </a>
                  ) : (
                    <article class={`showcase-card${item.localCoverPath ? '' : ' showcase-card--wide-media'}`}>
                      <div class="entry-card__media">
                        {item.localCoverPath ? <img src={item.localCoverPath} alt={item.title} loading="lazy" /> : null}
                      </div>
                      <div class="entry-card__body">
                        <span class="card-tag">{panelCopy.albums.tag}</span>
                        <h3 class="entry-card__title">{item.title}</h3>
                        {item.description ? <p class="entry-card__desc">{item.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                        <div class="entry-card__meta">
                          {item.artist && <div><strong>Artist:</strong> {Array.isArray(item.artist) ? item.artist.join(', ') : item.artist}</div>}
                          {item.publisher && <div><strong>Publisher:</strong> {Array.isArray(item.publisher) ? item.publisher.join(', ') : item.publisher}</div>}
                          {item.releaseDate && <div><strong>Release:</strong> {item.releaseDate}</div>}
                        </div>
                      </div>
                    </article>
                  )
                ))}
              </div>
            ) : (
              <div class="empty-state">No albums added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="other">
            <div class="content-panel__summary">
              <p class="section-eyebrow" id="section-eyebrow-other">{panelCopy.other.eyebrow}</p>
              <h3>{panelCopy.other.title}</h3>
              <p>{panelCopy.other.desc}</p>
            </div>
            <div class="prose-card">
              <OtherContent />
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const viewer = document.querySelector('[data-content-viewer]');
    const tabs = Array.from(document.querySelectorAll('[data-view]'));
    const panels = Array.from(document.querySelectorAll('[data-panel]'));
    
    // 处理向下箭头按钮的点击事件
    const scrollLink = document.querySelector('.hero-scroll-link');
    if (scrollLink) {
      scrollLink.addEventListener('click', (event) => {
        event.preventDefault();
        
        // 获取content-tabs元素
        const contentTabs = document.getElementById('content-tabs');
        if (!contentTabs) return;
        
        // 计算元素相对于文档顶部的绝对位置
        const rect = contentTabs.getBoundingClientRect();
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const targetPosition = rect.top + scrollTop;
        
        // 平滑滚动到目标位置
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
      });
    }

    if (viewer && tabs.length && panels.length) {
      const keys = tabs.map((tab) => tab.dataset.view);
      const tabsMap = Object.fromEntries(panels.map((panel) => [panel.dataset.panel, panel]));

      const setCurrentKey = (key) => {
        viewer.dataset.activeView = key;
      };

      const setActive = (key) => {
        if (!key || !tabsMap[key]) return;
        
        // 获取目标panel和它的第一个子元素（说明栏）
        const targetPanel = tabsMap[key];
        const firstChild = targetPanel.firstElementChild;
        const contentTabs = document.getElementById('content-tabs');
        
        if (contentTabs && firstChild) {
          const tabsRect = contentTabs.getBoundingClientRect();
          const firstChildRect = firstChild.getBoundingClientRect();
          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          
          // 判断菜单栏是否处于sticky状态（在视口顶部附近）
          const isTabsSticky = tabsRect.top >= -10 && tabsRect.top <= 20;
          
          if (isTabsSticky) {
            // 菜单栏已在顶部，需要向上微调使内容显示在菜单栏下方
            const tabsHeight = tabsRect.height;
            // 计算需要的滚动位置：使firstChild恰好显示在tabs下方
            const targetScrollTop = scrollTop + firstChildRect.top - tabsHeight - 20;
            
            // 只有当需要调整时才滚动
            if (Math.abs(firstChildRect.top - tabsHeight) > 10) {
              window.scrollTo({
                top: Math.max(0, targetScrollTop),
                behavior: 'smooth'
              });
            }
          } else {
            // 菜单栏不在顶部，向下滚动使tabs到达视口顶部（与箭头按钮行为一致）
            const targetScrollTop = tabsRect.top + scrollTop;
            
            if (Math.abs(tabsRect.top) > 10) {
              window.scrollTo({
                top: Math.max(0, targetScrollTop),
                behavior: 'smooth'
              });
            }
          }
        }
        
        tabs.forEach((tab) => tab.setAttribute('aria-selected', 'false'));
        panels.forEach((panel) => panel.removeAttribute('data-active'));
        tabsMap[key].setAttribute('data-active', 'true');
        const activeTab = tabs.find((t) => t.dataset.view === key);
        if (activeTab) activeTab.setAttribute('aria-selected', 'true');
        setCurrentKey(key);
      };

      const getCurrentKey = () => viewer.dataset.activeView || 'games';

      const move = (direction) => {
        const currentKey = getCurrentKey();
        const currentIndex = keys.indexOf(currentKey);
        const nextIndex = direction === 'next'
          ? (currentIndex + 1) % keys.length
          : (currentIndex - 1 + keys.length) % keys.length;
        setActive(keys[nextIndex] || 'games');
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => setActive(tab.dataset.view || 'games'));
      });

      setActive('games');
    }
  });
</script>
