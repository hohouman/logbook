---
import Layout from '../layouts/Layout.astro';
import OtherContent from '../content/posts/other.md';
import profile from '../config/profile.json';
import { OTHER_SECTION } from '../lib/collections';
---

<Layout title="Other" wallpaper={profile.wallpaper}>
  <div slot="hero" class="page-hero">
    <p class="page-kicker">Collection / Other</p>
    <h1>Other Interests</h1>
    <p>{OTHER_SECTION.title}</p>
    <div class="pill-row">
      <span class="stat-chip">Music</span>
      <span class="stat-chip">Travel</span>
      <span class="stat-chip">Tech</span>
    </div>
  </div>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Notes</p>
        <h2 class="section-title">My Other Interests</h2>
      </div>
      <p class="section-lead">{OTHER_SECTION.title}</p>
    </div>

    <div class="glass-panel prose-card">
      <OtherContent />
    </div>
  </section>
</Layout>
