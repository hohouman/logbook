---
import Layout from '../layouts/Layout.astro';
import profile from '../config/profile.json';
import gamesData from '../content/_generated/games.json';

const games = Array.isArray(gamesData) ? gamesData : (gamesData.items || []);
---

<Layout title="Games" wallpaper={profile.wallpaper}>
  <div slot="hero" class="page-hero">
    <p class="page-kicker">Collection / Games</p>
    <h1>Games</h1>
    <p>那些我玩过的游戏</p>
    <div class="pill-row">
      <span class="stat-chip">{games.length} items</span>
      <span class="stat-chip">Steam</span>
      <span class="stat-chip">Cover-first layout</span>
    </div>
  </div>

  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Library</p>
        <h2 class="section-title">My Game Collection</h2>
      </div>
      <p class="section-lead">那些我玩过的游戏</p>
    </div>

    {games.length > 0 ? (
      <div class="collection-grid">
        {games.map((game) => (
          <a href={game.url} target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit;">
            <article class={`entry-card entry-card--compact${game.localPosterPath ? '' : ' entry-card--wide-media'}`} key={game.id}>
              <div class="entry-card__media">
                {game.localPosterPath || game.localCoverPath ? <img src={game.localPosterPath || game.localCoverPath} alt={game.title} loading="lazy" /> : null}
              </div>
              <div class="entry-card__body">
                <span class="card-tag">Game</span>
                <h3 class="entry-card__title">{game.title}</h3>
                {game.description ? <p class="entry-card__desc">{game.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                <div class="entry-card__meta">
                  <div><strong>Developer:</strong> {Array.isArray(game.developer) ? game.developer.join(', ') : game.developer || 'Unknown'}</div>
                  <div><strong>Publisher:</strong> {Array.isArray(game.publisher) ? game.publisher.join(', ') : game.publisher || 'Unknown'}</div>
                  <div><strong>Release:</strong> {game.releaseDate || 'TBA'}</div>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">No games added yet. Check back later!</div>
    )}
  </section>
</Layout>
