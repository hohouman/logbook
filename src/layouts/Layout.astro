---
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import profile from '../config/profile.json';
import { collectionList, OTHER_SECTION } from '../lib/collections';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  wallpaper?: string;
  heroFullscreen?: boolean;
}

const { title, description, image, wallpaper, heroFullscreen } = Astro.props;
const heroWallpaper = wallpaper || profile.wallpaper;
const siteTitle = profile.name || 'logbook';
const heroClass = heroFullscreen ? 'hero-banner hero-banner--fullscreen' : 'hero-banner';
const pageClass = heroFullscreen ? 'page-main page-main--landing' : 'page-main';
const pageFrameClass = heroFullscreen
  ? 'glass-panel glass-panel--acrylic page-frame page-frame--landing'
  : 'glass-panel glass-panel--soft page-frame';

const navItems = [
  ...collectionList.map((config) => ({ href: `/${config.key}`, label: config.navLabel })),
  { href: `/${OTHER_SECTION.key}`, label: OTHER_SECTION.navLabel },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ? `${title} - ${siteTitle}` : siteTitle}</title>
  <meta name="description" content={description || profile.bio} />
  <meta property="og:title" content={title ? `${title} - ${siteTitle}` : siteTitle} />
  <meta property="og:description" content={description || profile.bio} />
  {image ? <meta property="og:image" content={image} /> : null}
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Serif+SC:wght@500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="site-shell">
    <section class={heroClass} data-hero-wallpaper={heroFullscreen ? heroWallpaper : undefined}>
      <img src={heroWallpaper} alt="背景封面" class="hero-banner-image" />
      <div class="hero-banner-overlay"></div>
      <div class={`hero-banner-content${heroFullscreen ? ' hero-banner-content--landing' : ''}`}>
        <slot name="hero" />
      </div>
      {heroFullscreen ? (
        <a class="hero-scroll-link">
          <span class="hero-scroll-link__arrow" aria-hidden="true">↓</span>
        </a>
      ) : null}
    </section>

    <main class={pageClass}>
      {!heroFullscreen ? (
        <header class="site-header">
          <a href="/" class="site-brand">
            <span class="site-brand-mark"></span>
            <span>{siteTitle}</span>
          </a>
          <nav class="site-nav" aria-label="主导航">
            {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </header>
      ) : null}
      <div class={pageFrameClass}>
        <slot />
      </div>
    </main>

    <Footer />
  </div>

  <script>
    import { initTheme } from '../lib/theme';

    const hero = document.querySelector<HTMLElement>('.hero-banner--fullscreen');
    const wallpaper = hero?.dataset.heroWallpaper;
    if (wallpaper) {
      initTheme(wallpaper);
    }
  </script>
</body>
</html>
